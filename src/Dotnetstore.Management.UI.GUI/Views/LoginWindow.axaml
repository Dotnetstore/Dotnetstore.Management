<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Dotnetstore.Management.UI.GUI.ViewModels"
        x:Class="Dotnetstore.Management.UI.GUI.Views.LoginWindow"
        x:DataType="vm:LoginViewModel"
        Title="Sign in"
        Width="460" Height="560"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent">
    <Window.KeyBindings>
        <KeyBinding Gesture="Enter" Command="{Binding LoginCommand}"/>
    </Window.KeyBindings>

    <Panel>
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial BackgroundSource="Digger"
                                             TintColor="#0B1020"
                                             TintOpacity="1"
                                             MaterialOpacity="0.8"/>
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <Border CornerRadius="14" BorderThickness="1" BorderBrush="#22FFFFFF" Margin="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Offset="0" Color="#1A1F3A"/>
                    <GradientStop Offset="1" Color="#0B1020"/>
                </LinearGradientBrush>
            </Border.Background>

            <StackPanel Margin="44,48" Spacing="18" VerticalAlignment="Center">
                <Border Width="56" Height="56" CornerRadius="14" HorizontalAlignment="Left">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Offset="0" Color="#6366F1"/>
                            <GradientStop Offset="1" Color="#8B5CF6"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock Text="D" FontSize="30" FontWeight="Bold"
                               Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Spacing="4">
                    <TextBlock Text="Welcome back"
                               FontSize="26" FontWeight="SemiBold"
                               Foreground="#F5F7FF"/>
                    <TextBlock Text="Sign in to your Dotnetstore account"
                               FontSize="13"
                               Foreground="#8B93B8"/>
                </StackPanel>

                <StackPanel Spacing="6" Margin="0,6,0,0">
                    <TextBlock Text="Email" FontSize="12" Foreground="#8B93B8"/>
                    <TextBox Name="EmailTextBox"
                             Text="{Binding Email, Mode=TwoWay}"
                             Watermark="you@example.com"
                             FontSize="14"
                             Padding="12,10"
                             CornerRadius="8"
                             Background="#151A33"
                             BorderBrush="#2A3052"
                             Foreground="#F5F7FF"/>
                </StackPanel>

                <StackPanel Spacing="6">
                    <TextBlock Text="Password" FontSize="12" Foreground="#8B93B8"/>
                    <TextBox Text="{Binding Password, Mode=TwoWay}"
                             PasswordChar="•"
                             Watermark="••••••••"
                             FontSize="14"
                             Padding="12,10"
                             CornerRadius="8"
                             Background="#151A33"
                             BorderBrush="#2A3052"
                             Foreground="#F5F7FF"/>
                </StackPanel>

                <TextBlock Text="{Binding ErrorMessage}"
                           Foreground="#F87171"
                           FontSize="12"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"/>

                <Button Content="Sign in"
                        Command="{Binding LoginCommand}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Height="44"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        CornerRadius="8"
                        Margin="0,6,0,0">
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                            <GradientStop Offset="0" Color="#6366F1"/>
                            <GradientStop Offset="1" Color="#8B5CF6"/>
                        </LinearGradientBrush>
                    </Button.Background>
                </Button>
            </StackPanel>
        </Border>
    </Panel>
</Window>
